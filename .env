# Alpaca API Keys
APCA_API_KEY_ID=your_paper_key_here
APCA_API_SECRET_KEY=your_paper_secret_here

# Trading Parameters
SYMBOLS=ETH/USD,BTC/USD,SOL/USD
TIMEFRAME=30Min
SENSITIVITY=1.0
ATR_PERIOD=10
TREND_EMA=200
HEIKIN_ASHI=False
PAPER_TRADING=True
QUANTITY=0.01

# Grid Stop Settings
GRID_SIZE=0.001          # 0.1% grid spacing
FIRST_PROFIT_LEVEL=0.009 # 0.9% before first stop activates

# Risk Management
STOP_LOSS_PERCENT=0.05

# Spread & Fee Protection (Prevents buying high/selling low)
SPREAD_PERCENT=0.003      # 0.3% bid-ask spread
FEE_PERCENT=0.0025        # 0.25% trading fee
MIN_NET_PROFIT=0.50       # Minimum $0.50 net profit after costs

# Account Settings
STARTING_BALANCE=100000.00

# Individual symbol quantities
QUANTITY_ETH=0.021
QUANTITY_BTC=0.00021
QUANTITY_SOL=0.21
