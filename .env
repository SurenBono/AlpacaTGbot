# Alpaca API Keys
APCA_API_KEY_ID=your_paper_key_here
APCA_API_SECRET_KEY=your_paper_secret_here

# Trading Parameters
SYMBOLS=ETH/USD,BTC/USD,SOL/USD
TIMEFRAME=30Min
SENSITIVITY=1.0
ATR_PERIOD=10
TREND_EMA=200
HEIKIN_ASHI=False
PAPER_TRADING=True
QUANTITY=0.01

# Grid Stop Settings
GRID_SIZE=0.001          # 0.1% grid spacing
FIRST_PROFIT_LEVEL=0.009 # 0.9% before first stop activates

# Risk Management
STOP_LOSS_PERCENT=0.05

# Spread & Fee Protection (Prevents buying high/selling low)
SPREAD_PERCENT=0.003      # 0.3% bid-ask spread
FEE_PERCENT=0.0025        # 0.25% trading fee
MIN_NET_PROFIT=0.50       # Minimum $0.50 net profit after costs

# Account Settings
STARTING_BALANCE=100000.00

# Individual symbol quantities
QUANTITY_ETH=0.021
QUANTITY_BTC=0.00021
QUANTITY_SOL=0.21

# Manual Bot Settings
DEFAULT_QUANTITY=0.01
TARGET_PROFIT_PERCENT=0.05   # 5% target profit

# For individual symbol quantities (optional)
QUANTITY_AAVE=0.01
QUANTITY_AVAX=0.1
QUANTITY_BAT=10
QUANTITY_BCH=20
QUANTITY_BTC=0.0002
QUANTITY_CRV=5
QUANTITY_DOT=0.5
QUANTITY_ETH=0.01
QUANTITY_GRT=20
QUANTITY_LINK=0.5
QUANTITY_LTC=0.05
QUANTITY_MKR=0.005
QUANTITY_SHIB=500000
QUANTITY_UNI=0.5
QUANTITY_XTZ=1
